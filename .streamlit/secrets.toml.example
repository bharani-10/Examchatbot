# ─────────────────────────────────────────────────────────────────────────────
# Rename this file to secrets.toml and fill in your values.
# For Streamlit Cloud: paste each key-value into the Secrets panel
# (App Settings → Secrets) — do NOT commit the real secrets.toml to Git.
# ─────────────────────────────────────────────────────────────────────────────

GROQ_API_KEY        = "your_groq_api_key_here"
FIREBASE_API_KEY    = "your_firebase_web_api_key_here"
FIREBASE_PROJECT_ID = "your_firebase_project_id_here"
FIREBASE_DATABASE_URL = "https://your_project_id.firebaseio.com"
